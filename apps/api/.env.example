# ─────────────────────────────────────────────
# einfach verwaltet. API — Environment Config
# Copy to .env and fill in values
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=change_me_in_production_minimum_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# Database (Neon PostgreSQL)
# If not set, API will use in-memory mock data (clearly marked)
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/propos?sslmode=require

# Anthropic (Claude) — for /api/ai/chat
ANTHROPIC_API_KEY=sk-ant-xxx

# CORS — allowed origins
CORS_ORIGINS=http://localhost:3000,https://einfachverwaltet.de

# Internal API key for service-to-service calls
INTERNAL_API_KEY=change_me_internal_key
