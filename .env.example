# Resend API key — get yours at https://resend.com (free tier: 3,000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Neon Database URL — get yours at https://neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://username:password@host.region.aws.neon.tech/database?sslmode=require

# Admin Secret Key for /admin/leads access
# Access the dashboard at: /admin/leads?key=your-secret-key
ADMIN_SECRET_KEY=change-this-to-a-random-secret-key

# ── Portal Auth ───────────────────────────────────────────────────────────────
# JWT secret for signing portal session cookies (use a long random string)
# Generate: openssl rand -base64 32
JWT_SECRET=change-this-to-a-long-random-secret

# Demo landlord email — when set, magic-link returns the token in the JSON response
# so you can test login without an email server configured
DEMO_LANDLORD_EMAIL=demo@einfach-verwaltet.de

# Public app URL (used to build verify links in emails)
NEXT_PUBLIC_APP_URL=https://einfach-verwaltet.de

# Google Analytics 4 Measurement ID
# Get yours at https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Ads Conversion ID
# Get yours from your Google Ads account (Tools > Conversions)
# Format: AW-XXXXXXXXXX/XXXXXXXXXXX
NEXT_PUBLIC_GADS_CONVERSION_ID=AW-XXXXXXXXXX/XXXXXXXXXXX
