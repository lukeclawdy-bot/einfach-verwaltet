# Resend API key — get yours at https://resend.com (free tier: 3,000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Neon Database URL — get yours at https://neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://username:password@host.region.aws.neon.tech/database?sslmode=require

# Admin Secret Key for /admin/leads access
# Access the dashboard at: /admin/leads?key=your-secret-key
ADMIN_SECRET_KEY=change-this-to-a-random-secret-key

# ── Portal Auth ───────────────────────────────────────────────────────────────
# JWT secret for signing portal session cookies (use a long random string)
# Generate: openssl rand -base64 32
JWT_SECRET=change-this-to-a-long-random-secret

# Demo landlord email — when set, magic-link returns the token in the JSON response
# so you can test login without an email server configured
DEMO_LANDLORD_EMAIL=demo@einfach-verwaltet.de

# Public app URL (used to build verify links in emails)
NEXT_PUBLIC_APP_URL=https://einfach-verwaltet.de

# Google Analytics 4 Measurement ID
# Get yours at https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Ads Conversion ID
# Get yours from your Google Ads account (Tools > Conversions)
# Format: AW-XXXXXXXXXX/XXXXXXXXXXX
NEXT_PUBLIC_GADS_CONVERSION_ID=AW-XXXXXXXXXX/XXXXXXXXXXX

# ── Stripe Billing ────────────────────────────────────────────────────────────
# Stripe API keys — get yours at https://dashboard.stripe.com/apikeys
# Test keys start with sk_test_ / pk_test_; live keys with sk_live_ / pk_live_
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Webhook Secret — from Stripe Dashboard > Webhooks > your endpoint
# Or get from CLI: stripe listen --print-secret
# Endpoint to register: https://einfach-verwaltet.de/api/portal/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs — create products in Stripe Dashboard > Products
# Then copy the Price IDs (price_xxxx) for each tier:
#   - Mietverwaltung Basis: €34/unit/month (for 1-10 units)
#   - Mietverwaltung Standard: €29/unit/month (for 11-50 units)
#   - Mietverwaltung Professional: €24/unit/month (for 51-200 units)
STRIPE_PRICE_BASIC=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_STANDARD=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PROFESSIONAL=price_xxxxxxxxxxxxxxxxxxxx

# ── WhatsApp Business (360dialog) ─────────────────────────────────────────────
# 360dialog API key — get at https://hub.360dialog.com
# Cost: €50/month base + €0.02-0.05/message
# Setup: see Core Processes note in Mission Control
WHATSAPP_API_KEY=your-360dialog-api-key

# WhatsApp Business phone number ID (from 360dialog dashboard)
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Webhook verification token — set the same value in 360dialog dashboard
# Webhook URL: https://einfach-verwaltet.de/api/webhooks/whatsapp
WHATSAPP_WEBHOOK_VERIFY_TOKEN=einfach-verwaltet-whatsapp

# ── DATEV Export ──────────────────────────────────────────────────────────────
# Optional: Your DATEV Steuerberater number (shown in exported DATEV files)
# If not set, defaults to 00000
DATEV_BERATER_NR=00000

# Optional: Your DATEV Mandant number (assigned by Steuerberater)
DATEV_MANDANT_NR=00001
